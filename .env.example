# =============================================================================
# CARDBUY — Variables de entorno
# Copia este archivo a .env y rellena los valores reales.
# NUNCA subas .env al repositorio.
# =============================================================================

# -----------------------------------------------------------------------------
# ENTORNO
# -----------------------------------------------------------------------------
NODE_ENV=development
APP_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# BASE DE DATOS (PostgreSQL)
# -----------------------------------------------------------------------------
POSTGRES_USER=cardbuy
POSTGRES_PASSWORD=cardbuy_secret
POSTGRES_DB=cardbuy_dev
DATABASE_URL="postgresql://cardbuy:cardbuy_secret@localhost:5432/cardbuy_dev"

# -----------------------------------------------------------------------------
# CACHE (Redis)
# -----------------------------------------------------------------------------
REDIS_PASSWORD=redis_secret
REDIS_URL="redis://:redis_secret@localhost:6379"

# -----------------------------------------------------------------------------
# STORAGE (MinIO local / Cloudflare R2 en producción)
# -----------------------------------------------------------------------------
MINIO_ROOT_USER=cardbuy_minio
MINIO_ROOT_PASSWORD=minio_secret_123
MINIO_ENDPOINT=http://localhost:9000
MINIO_BUCKET_CARDS=cards
MINIO_BUCKET_KYC=kyc-documents
MINIO_BUCKET_DISPUTES=dispute-evidence

# Storage público (URL base para imágenes de cartas)
STORAGE_PUBLIC_URL=http://localhost:9000/cards

# -----------------------------------------------------------------------------
# AUTENTICACIÓN (NextAuth.js v5)
# -----------------------------------------------------------------------------
NEXTAUTH_SECRET=change_me_in_production_use_openssl_rand_base64_32
NEXTAUTH_URL=http://localhost:3000

# OAuth providers (opcional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# PAGOS (Stripe)
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Connect (para sellers)
STRIPE_CONNECT_CLIENT_ID=ca_...

# -----------------------------------------------------------------------------
# EMAIL (Resend / SMTP)
# -----------------------------------------------------------------------------
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@cardbuy.com

# -----------------------------------------------------------------------------
# KYC/KYB (Stripe Identity o Veriff)
# -----------------------------------------------------------------------------
KYC_PROVIDER=stripe_identity
# VERIFF_API_KEY=
# VERIFF_SECRET=

# -----------------------------------------------------------------------------
# ANTIFRAUDE
# -----------------------------------------------------------------------------
# MaxMind GeoIP2 (detección de IPs fraudulentas)
MAXMIND_ACCOUNT_ID=
MAXMIND_LICENSE_KEY=

# -----------------------------------------------------------------------------
# TCG DATA PROVIDERS
# -----------------------------------------------------------------------------
# Pokémon TCG API
POKEMON_TCG_API_KEY=

# Scryfall (MTG) — sin key para uso básico
SCRYFALL_API_URL=https://api.scryfall.com

# Yu-Gi-Oh! DB — sin key para uso básico
YGOPRODECK_API_URL=https://db.ygoprodeck.com/api/v7

# -----------------------------------------------------------------------------
# SEO / ANALYTICS
# -----------------------------------------------------------------------------
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-...
NEXT_PUBLIC_SITE_NAME=CardBuy
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# GITHUB (para scripts de automatización)
# -----------------------------------------------------------------------------
GH_TOKEN=ghp_...
PROJECT_TOKEN=ghp_...
PROJECT_NUMBER=1
GITHUB_REPO=juanmbarrios/cardbuy

# -----------------------------------------------------------------------------
# RATE LIMITING
# -----------------------------------------------------------------------------
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
